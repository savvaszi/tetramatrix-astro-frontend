// Get static paths - combine Directus and fallback slugs
export async function getStaticPaths() {
  const directusCaseStudies = await getCaseStudies();
  const directusSlugs = directusCaseStudies.map(cs => cs.slug);
  const fallbackSlugs = Object.keys(fallbackCaseStudies);
  const allSlugs = [...new Set([...directusSlugs, ...fallbackSlugs])];
  
  return allSlugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;

// Try to fetch from Directus first, then fallback to static data
const directusCaseStudy = await getCaseStudyBySlug(slug as string);

let caseStudy: any;
if (directusCaseStudy) {
  // Transform Directus data
  const screenshotUrls = directusCaseStudy.screenshots?.map(s => {
    const fileId = typeof s.directus_files_id === 'string' ? s.directus_files_id : s.directus_files_id?.id;
    return getImageUrl(fileId);
  }).filter(Boolean) || [];
  
  caseStudy = {
    name: directusCaseStudy.name,
    url: directusCaseStudy.url || '',
    type: directusCaseStudy.type || '',
    image: getImageUrl(getFileId(directusCaseStudy.featured_image)) || 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=1200&h=800&fit=crop',
    description: directusCaseStudy.description || '',
    challenge: directusCaseStudy.challenge || '',
    solution: directusCaseStudy.solution || '',
    technologies: directusCaseStudy.technologies || [],
    features: directusCaseStudy.features || [],
    screenshots: screenshotUrls.length > 0 ? screenshotUrls : ['https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&h=500&fit=crop'],
  };
} else {
  // Use fallback static data
  caseStudy = fallbackCaseStudies[slug as string];
}

if (!caseStudy) {
  return Astro.redirect('/404');
}
---

<Layout title={`${caseStudy.name} - Case Study`} description={caseStudy.description}>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-primary via-primary-dark to-dark py-20 lg:py-28">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-20 right-20 w-72 h-72 bg-teal rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 left-10 w-96 h-96 bg-accent rounded-full blur-3xl"></div>
    </div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/#case-studies" class="inline-flex items-center gap-2 text-teal-light hover:text-white mb-6 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Case Studies
      </a>
      
      <span class="inline-block text-teal-light font-semibold text-sm uppercase tracking-wider mb-4">{caseStudy.type}</span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6">
        {caseStudy.name}
      </h1>
      <p class="text-xl text-gray-300 max-w-3xl">
        {caseStudy.description}
      </p>
      
      <div class="mt-8">
        <a 
          href={caseStudy.url} 
          target="_blank" 
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-teal hover:bg-teal-light text-white px-6 py-3 rounded-lg font-semibold transition-all duration-200"
        >
          Visit Live Site
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Image -->
  <section class="py-12 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl overflow-hidden shadow-2xl">
        <img 
          src={caseStudy.image} 
          alt={caseStudy.name}
          class="w-full h-auto object-cover"
        />
      </div>
    </div>
  </section>

  <!-- Challenge & Solution -->
  <section class="py-20 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12">
        <div class="bg-white rounded-2xl p-8 shadow-lg">
          <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">The Challenge</h3>
          <p class="text-gray-600 text-lg">{caseStudy.challenge}</p>
        </div>
        
        <div class="bg-white rounded-2xl p-8 shadow-lg">
          <div class="w-12 h-12 bg-teal/10 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Our Solution</h3>
          <p class="text-gray-600 text-lg">{caseStudy.solution}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Technologies & Features -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Technologies -->
        <div>
          <h3 class="text-2xl font-bold text-gray-900 mb-6">Technologies Used</h3>
          <div class="flex flex-wrap gap-3">
            {caseStudy.technologies.map((tech: string) => (
              <span class="bg-primary/10 text-primary px-4 py-2 rounded-lg font-medium">
                {tech}
              </span>
            ))}
          </div>
        </div>
        
        <!-- Features -->
        <div>
          <h3 class="text-2xl font-bold text-gray-900 mb-6">Key Features</h3>
          <ul class="space-y-3">
            {caseStudy.features.map((feature: string) => (
              <li class="flex items-center gap-3 text-gray-700">
                <svg class="w-5 h-5 text-teal flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Screenshots Gallery -->
  <section class="py-20 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h3 class="text-2xl font-bold text-gray-900 mb-8 text-center">Project Screenshots</h3>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {caseStudy.screenshots.map((screenshot: string, index: number) => (
          <div class="rounded-xl overflow-hidden shadow-lg hover:shadow-2xl transition-shadow">
            <img 
              src={screenshot} 
              alt={`${caseStudy.name} screenshot ${index + 1}`}
              class="w-full h-64 object-cover hover:scale-105 transition-transform duration-300"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-gradient-to-br from-primary via-primary-dark to-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
        Ready to Start Your Project?
      </h2>
      <p class="text-xl text-gray-300 mb-8">
        Let's create something amazing together. Contact us to discuss your project requirements.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-teal hover:bg-teal-light text-white px-8 py-4 rounded-lg font-semibold transition-all duration-200 shadow-lg hover:shadow-xl">
          Get in Touch
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="/" class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white px-8 py-4 rounded-lg font-semibold transition-all duration-200 backdrop-blur-sm border border-white/20">
          View More Projects
        </a>
      </div>
    </div>
  </section>
</Layout>
