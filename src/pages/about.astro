---
import Layout from '../layouts/Layout.astro';

const qualities = [
  {
    title: 'Quality',
    description: 'Tetramatrix is committed to providing our clients with the highest quality services. We take pride in our work and we are always striving to improve. We also have a rigorous quality control process in place to ensure that our work meets the highest standards.',
    details: 'We understand that your website is an important part of your business, and we are committed to creating a website that is both effective and engaging. We also understand that SEO is essential for driving traffic to your website, and we have a team of experts who can help you improve your SEO ranking.',
  },
  {
    title: 'Skills',
    description: 'Tetramatrix is a team of highly skilled and experienced professionals who are passionate about their work. We have a deep understanding of the digital landscape and the latest technologies.',
    skills: [
      'Web design and development',
      'Search engine optimization (SEO)',
      'Social media marketing',
      'Content marketing',
      'Email marketing',
      'Paid advertising',
      'Analytics and reporting',
    ],
  },
  {
    title: 'Passion',
    description: 'We are passionate about helping businesses succeed online. We believe that every business has the potential to succeed online, and we are committed to helping them achieve their goals.',
    details: 'We work closely with our clients to understand their needs and develop customized solutions that meet their unique goals. We are also passionate about the digital landscape and the latest technologies. We are always looking for new and innovative ways to help our clients succeed.',
  },
];
---

<Layout title="About Us" description="Tetramatrix - Your web agency for the digital age. Quality, Skills, and Passion.">
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-primary via-primary-dark to-dark py-20 lg:py-28">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-20 right-20 w-72 h-72 bg-teal rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 left-10 w-96 h-96 bg-accent rounded-full blur-3xl"></div>
    </div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block text-teal-light font-semibold text-sm uppercase tracking-wider mb-4">About Us</span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6">
        Your Web Agency for the Digital Age
      </h1>
      <p class="text-xl text-gray-300 max-w-3xl mx-auto">
        Tetramatrix is a full-service web agency that helps businesses of all sizes achieve their online goals.
      </p>
    </div>
  </section>

  <!-- Qualities Section -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-12">
        {qualities.map((quality) => (
          <div class="bg-gray-light rounded-2xl p-8 hover:shadow-xl transition-shadow">
            <h3 class="text-2xl font-bold text-gray-900 mb-4">{quality.title}</h3>
            <p class="text-gray-600 mb-4">{quality.description}</p>
            {quality.details && (
              <p class="text-gray-600">{quality.details}</p>
            )}
            {quality.skills && (
              <ul class="space-y-2 mt-4">
                {quality.skills.map((skill: string) => (
                  <li class="flex items-center gap-2 text-gray-700">
                    <svg class="w-5 h-5 text-teal flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {skill}
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Let's Work Together Section -->
  <section class="py-20 lg:py-28 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
            Let's Work Together!
          </h2>
          <p class="text-gray-600 text-lg mb-6">
            Tetramatrix is a full-service web agency that helps businesses of all sizes achieve their online goals. We specialize in web design and development, search engine optimization (SEO), and social media marketing.
          </p>
          <p class="text-gray-600 text-lg mb-6">
            We understand that the digital landscape is constantly changing, and we are committed to staying ahead of the curve. We use the latest technologies and best practices to create effective and engaging online experiences for our clients.
          </p>
          <p class="text-gray-600 text-lg mb-8">
            Our team of experienced and talented professionals is passionate about helping businesses succeed online. We work closely with our clients to understand their needs and develop customized solutions that meet their unique goals.
          </p>
          <a href="/contact" class="inline-flex items-center gap-2 bg-teal hover:bg-teal-light text-white px-6 py-3 rounded-lg font-semibold transition-all duration-200">
            Contact Us
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
        
        <div class="relative">
          <img 
            src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=600&h=500&fit=crop" 
            alt="Team collaboration" 
            class="w-full rounded-2xl shadow-2xl"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Mission Section -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <span class="text-teal font-semibold text-sm uppercase tracking-wider">Our Mission</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-3 mb-6">
          Turn Ideas into Reality
        </h2>
        <p class="text-gray-600 text-lg mb-6">
          Tetramatrix's mission is to make client's ideas into reality. This is a beautiful mission because it is all about helping people to achieve their dreams. When you come to Tetramatrix with an idea, you are putting your trust in the team to help you make it a reality.
        </p>
        <p class="text-gray-600 text-lg mb-6">
          The team at Tetramatrix is passionate about helping their clients succeed. We understand that every client has unique needs and goals, and we work closely with each client to develop a customized solution that meets those needs.
        </p>
        <p class="text-gray-600 text-lg">
          Tetramatrix also has a deep understanding of the digital landscape and the latest technologies, which allows us to create websites and online experiences that are both effective and engaging.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-gradient-to-br from-primary via-primary-dark to-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
        Ready to Get Started?
      </h2>
      <p class="text-xl text-gray-300 mb-8">
        If you are looking for a web agency that can help you take your business to the next level, contact Tetramatrix today. We offer a free consultation to discuss your needs and how we can help you achieve your goals.
      </p>
      <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-teal hover:bg-teal-light text-white px-8 py-4 rounded-lg font-semibold transition-all duration-200 shadow-lg hover:shadow-xl">
        Get in Touch
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>
</Layout>
