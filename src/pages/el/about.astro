---
import Layout from '../../layouts/Layout.astro';
import { t } from '../../lib/i18n';

const lang = 'el';

const milestones = [
  { year: '2018', title: 'Ίδρυση', description: 'Η TetraMatrix ιδρύθηκε με όραμα να παρέχει κορυφαίες IT λύσεις στην Κύπρο.' },
  { year: '2019', title: 'Πρώτοι Μεγάλοι Πελάτες', description: 'Αναλάβαμε τα πρώτα μεγάλα έργα για επιχειρήσεις στην Κύπρο.' },
  { year: '2021', title: 'Επέκταση Υπηρεσιών', description: 'Προσθέσαμε υπηρεσίες hosting και managed IT services.' },
  { year: '2023', title: 'Tetrapos Launch', description: 'Λανσάρισμα του Tetrapos - το δικό μας POS σύστημα.' },
];

const team = [
  { name: 'Savvas Zenonos', role: 'Ιδρυτής & CEO', bio: 'Πάνω από 10 χρόνια εμπειρίας στην ανάπτυξη λογισμικού.' },
];
---

<Layout title={t(lang, 'about.title')} lang={lang}>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-primary via-primary-dark to-dark py-20 lg:py-28 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-20 left-10 w-72 h-72 bg-teal rounded-full blur-3xl"></div>
      <div class="absolute bottom-20 right-10 w-96 h-96 bg-accent rounded-full blur-3xl"></div>
    </div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block bg-teal/20 text-teal-light px-4 py-2 rounded-full text-sm font-semibold mb-6">
        {t(lang, 'about.title')}
      </span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
        Η Ιστορία Μας
      </h1>
      <p class="text-xl text-gray-300 max-w-3xl mx-auto">
        Είμαστε μια ομάδα παθιασμένων επαγγελματιών IT που βοηθάμε επιχειρήσεις να πετύχουν στον ψηφιακό κόσμο.
      </p>
    </div>
  </section>

  <!-- About Content -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
            Ποιοι Είμαστε
          </h2>
          <p class="text-gray-600 text-lg mb-6">
            Η TetraMatrix είναι μια εταιρεία IT με έδρα την Κύπρο, εξειδικευμένη στην ανάπτυξη ιστοσελίδων, 
            εφαρμογών και ψηφιακών λύσεων για επιχειρήσεις κάθε μεγέθους.
          </p>
          <p class="text-gray-600 text-lg mb-6">
            Η αποστολή μας είναι να βοηθάμε τις επιχειρήσεις να αξιοποιήσουν την τεχνολογία για να αναπτυχθούν 
            και να πετύχουν τους στόχους τους.
          </p>
          <div class="grid grid-cols-2 gap-6 mt-8">
            <div class="text-center p-6 bg-gray-light rounded-xl">
              <div class="text-3xl font-bold text-primary">50+</div>
              <div class="text-gray-600">Έργα</div>
            </div>
            <div class="text-center p-6 bg-gray-light rounded-xl">
              <div class="text-3xl font-bold text-primary">5+</div>
              <div class="text-gray-600">Χρόνια Εμπειρίας</div>
            </div>
          </div>
        </div>
        <div class="relative">
          <img 
            src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=800&h=600&fit=crop" 
            alt="Η ομάδα μας"
            class="rounded-2xl shadow-2xl"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Milestones -->
  <section class="py-20 lg:py-28 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-teal font-semibold text-sm uppercase tracking-wider">{t(lang, 'about.milestones')}</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-3 mb-4">
          Η Πορεία Μας
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {milestones.map((milestone) => (
          <div class="bg-white rounded-2xl p-6 shadow-lg">
            <div class="text-2xl font-bold text-primary mb-2">{milestone.year}</div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">{milestone.title}</h3>
            <p class="text-gray-600 text-sm">{milestone.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-gradient-to-br from-primary via-primary-dark to-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
        Ας Συνεργαστούμε
      </h2>
      <p class="text-xl text-gray-300 mb-8">
        Επικοινωνήστε μαζί μας για να συζητήσουμε πώς μπορούμε να βοηθήσουμε την επιχείρησή σας.
      </p>
      <a href="/el/contact" class="inline-flex items-center justify-center gap-2 bg-teal hover:bg-teal-light text-white px-8 py-4 rounded-lg font-semibold transition-all duration-200 shadow-lg hover:shadow-xl">
        {t(lang, 'common.contactUs')}
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>
</Layout>
