---
import Layout from '../../layouts/Layout.astro';
import { t } from '../../lib/i18n';

const lang = 'el';
---

<Layout title={t(lang, 'contact.title')} lang={lang}>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-primary via-primary-dark to-dark py-20 lg:py-28 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-20 left-10 w-72 h-72 bg-teal rounded-full blur-3xl"></div>
      <div class="absolute bottom-20 right-10 w-96 h-96 bg-accent rounded-full blur-3xl"></div>
    </div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block bg-teal/20 text-teal-light px-4 py-2 rounded-full text-sm font-semibold mb-6">
        {t(lang, 'contact.title')}
      </span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
        {t(lang, 'contact.getInTouch')}
      </h1>
      <p class="text-xl text-gray-300 max-w-3xl mx-auto">
        Είμαστε εδώ για να βοηθήσουμε. Επικοινωνήστε μαζί μας για οποιαδήποτε ερώτηση.
      </p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Contact Info -->
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">Στοιχεία Επικοινωνίας</h2>
          <p class="text-gray-600 mb-8">
            Μπορείτε να επικοινωνήσετε μαζί μας μέσω email, τηλεφώνου ή να μας επισκεφθείτε στα γραφεία μας.
          </p>
          
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">Email</h3>
                <a href="mailto:info@tetramatrix.com.cy" class="text-primary hover:underline">info@tetramatrix.com.cy</a>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">{t(lang, 'contact.phone')}</h3>
                <a href="tel:+35799123456" class="text-primary hover:underline">+357 99 123 456</a>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">Διεύθυνση</h3>
                <p class="text-gray-600">Λεμεσός, Κύπρος</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="bg-gray-light rounded-2xl p-8">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Στείλτε μας Μήνυμα</h2>
          <form class="space-y-6">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-2">{t(lang, 'contact.name')}</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
                placeholder="Το όνομά σας"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-2">{t(lang, 'contact.email')}</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
                placeholder="email@example.com"
              />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-2">{t(lang, 'contact.message')}</label>
              <textarea 
                id="message" 
                name="message" 
                rows="5"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all resize-none"
                placeholder="Πώς μπορούμε να σας βοηθήσουμε;"
              ></textarea>
            </div>
            <button 
              type="submit"
              class="w-full bg-primary hover:bg-primary-light text-white px-8 py-4 rounded-lg font-semibold transition-all duration-200 shadow-lg hover:shadow-xl"
            >
              {t(lang, 'contact.sendMessage')}
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>
