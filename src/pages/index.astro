---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
    title: 'IT Consulting',
    description: 'Strategic technology guidance to align your IT infrastructure with business objectives.',
  },
  {
    icon: 'M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z',
    title: 'Cloud Solutions',
    description: 'Scalable cloud infrastructure and migration services for modern enterprises.',
  },
  {
    icon: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z',
    title: 'Cybersecurity',
    description: 'Comprehensive security solutions to protect your digital assets and data.',
  },
  {
    icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
    title: 'Software Development',
    description: 'Custom software solutions tailored to your unique business requirements.',
  },
  {
    icon: 'M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4',
    title: 'Data Analytics',
    description: 'Transform raw data into actionable insights with advanced analytics.',
  },
  {
    icon: 'M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z',
    title: 'IT Support',
    description: '24/7 technical support and maintenance for seamless operations.',
  },
];

const stats = [
  { value: '150+', label: 'Projects Completed' },
  { value: '50+', label: 'Happy Clients' },
  { value: '10+', label: 'Years Experience' },
  { value: '99%', label: 'Client Satisfaction' },
];

const team = [
  { name: 'Andreas Georgiou', role: 'CEO & Founder', image: 'https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=300&h=300&fit=crop&crop=face' },
  { name: 'Maria Constantinou', role: 'CTO', image: 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=300&h=300&fit=crop&crop=face' },
  { name: 'Nikos Papadopoulos', role: 'Lead Developer', image: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=300&h=300&fit=crop&crop=face' },
  { name: 'Elena Christodoulou', role: 'Security Specialist', image: 'https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=300&h=300&fit=crop&crop=face' },
];
---

<Layout title="Home">
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-primary via-primary-dark to-dark overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-20 left-10 w-72 h-72 bg-teal rounded-full blur-3xl"></div>
      <div class="absolute bottom-20 right-10 w-96 h-96 bg-accent rounded-full blur-3xl"></div>
    </div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm rounded-full px-4 py-2 mb-6">
            <span class="w-2 h-2 bg-teal-light rounded-full animate-pulse"></span>
            <span class="text-teal-light text-sm font-medium">Trusted IT Partner in Cyprus</span>
          </div>
          
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
            Transforming Business Through
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-teal-light to-accent"> Technology</span>
          </h1>
          
          <p class="text-lg text-gray-300 mb-8 max-w-xl">
            We deliver cutting-edge IT solutions that drive innovation, enhance security, and accelerate your digital transformation journey.
          </p>
          
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-teal hover:bg-teal-light text-white px-8 py-4 rounded-lg font-semibold transition-all duration-200 shadow-lg hover:shadow-xl">
              Start Your Project
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a href="/services" class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white px-8 py-4 rounded-lg font-semibold transition-all duration-200 backdrop-blur-sm border border-white/20">
              Explore Services
            </a>
          </div>
        </div>
        
        <div class="hidden lg:block relative">
          <div class="relative w-full aspect-square">
            <div class="absolute inset-0 bg-gradient-to-br from-teal/20 to-accent/20 rounded-3xl backdrop-blur-sm border border-white/10"></div>
            <div class="absolute inset-4 bg-gradient-to-br from-primary-light/50 to-primary/50 rounded-2xl flex items-center justify-center">
              <div class="grid grid-cols-2 gap-4 p-8">
                <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/10">
                  <svg class="w-10 h-10 text-teal-light mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                  <p class="text-white/80 text-sm">IT Solutions</p>
                </div>
                <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/10">
                  <svg class="w-10 h-10 text-accent mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />
                  </svg>
                  <p class="text-white/80 text-sm">Cloud Services</p>
                </div>
                <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/10">
                  <svg class="w-10 h-10 text-accent mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                  </svg>
                  <p class="text-white/80 text-sm">Security</p>
                </div>
                <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/10">
                  <svg class="w-10 h-10 text-teal-light mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                  </svg>
                  <p class="text-white/80 text-sm">Development</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white to-transparent"></div>
  </section>

  <!-- Services Section -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-teal font-semibold text-sm uppercase tracking-wider">Our Services</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-3 mb-4">
          Comprehensive IT Solutions
        </h2>
        <p class="text-gray-600 text-lg">
          From strategic consulting to hands-on implementation, we provide end-to-end technology services tailored to your needs.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service) => (
          <div class="group bg-gray-light rounded-2xl p-8 hover:bg-primary hover:shadow-2xl transition-all duration-300">
            <div class="w-14 h-14 bg-primary/10 group-hover:bg-white/20 rounded-xl flex items-center justify-center mb-6 transition-colors">
              <svg class="w-7 h-7 text-primary group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={service.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 group-hover:text-white mb-3 transition-colors">
              {service.title}
            </h3>
            <p class="text-gray-600 group-hover:text-gray-200 transition-colors">
              {service.description}
            </p>
          </div>
        ))}
      </div>

      <div class="text-center mt-12">
        <a href="/services" class="inline-flex items-center gap-2 text-primary hover:text-primary-light font-semibold transition-colors">
          View All Services
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-20 bg-gradient-to-r from-primary to-primary-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        {stats.map((stat) => (
          <div class="text-center">
            <div class="text-4xl md:text-5xl font-bold text-white mb-2">{stat.value}</div>
            <div class="text-teal-light font-medium">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <section class="py-20 lg:py-28 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="text-teal font-semibold text-sm uppercase tracking-wider">Why Choose Us</span>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-3 mb-6">
            Your Trusted Technology Partner
          </h2>
          <p class="text-gray-600 text-lg mb-8">
            With over a decade of experience in the IT industry, we've helped businesses across Cyprus and beyond achieve their digital transformation goals.
          </p>
          
          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="w-12 h-12 bg-teal/10 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">Proven Expertise</h3>
                <p class="text-gray-600">Certified professionals with deep industry knowledge and hands-on experience.</p>
              </div>
            </div>
            
            <div class="flex gap-4">
              <div class="w-12 h-12 bg-teal/10 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">Rapid Delivery</h3>
                <p class="text-gray-600">Agile methodologies ensure fast turnaround without compromising quality.</p>
              </div>
            </div>
            
            <div class="flex gap-4">
              <div class="w-12 h-12 bg-teal/10 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">24/7 Support</h3>
                <p class="text-gray-600">Round-the-clock technical support to keep your systems running smoothly.</p>
              </div>
            </div>
          </div>
        </div>
        
        <div class="relative">
          <div class="bg-white rounded-2xl shadow-xl p-8">
            <img 
              src="https://images.unsplash.com/photo-1551434678-e076c223a692?w=600&h=400&fit=crop" 
              alt="Team collaboration" 
              class="w-full h-64 object-cover rounded-xl mb-6"
            />
            <div class="flex items-center gap-4">
              <div class="flex -space-x-3">
                {team.slice(0, 3).map((member) => (
                  <img 
                    src={member.image} 
                    alt={member.name}
                    class="w-10 h-10 rounded-full border-2 border-white object-cover"
                  />
                ))}
              </div>
              <div>
                <p class="font-semibold text-gray-900">Expert Team</p>
                <p class="text-sm text-gray-600">Ready to help you succeed</p>
              </div>
            </div>
          </div>
          <div class="absolute -bottom-6 -left-6 bg-teal text-white rounded-xl p-6 shadow-lg">
            <div class="text-3xl font-bold">10+</div>
            <div class="text-teal-light text-sm">Years of Excellence</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section id="team" class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-teal font-semibold text-sm uppercase tracking-wider">Our Team</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-3 mb-4">
          Meet the Experts
        </h2>
        <p class="text-gray-600 text-lg">
          Our talented team of professionals is dedicated to delivering exceptional results for every project.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {team.map((member) => (
          <div class="group text-center">
            <div class="relative mb-6 overflow-hidden rounded-2xl">
              <img 
                src={member.image} 
                alt={member.name}
                class="w-full aspect-square object-cover group-hover:scale-105 transition-transform duration-300"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-primary/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end justify-center pb-6">
                <div class="flex gap-3">
                  <a href="#" class="w-10 h-10 bg-white/20 backdrop-blur-sm rounded-full flex items-center justify-center text-white hover:bg-white/30 transition-colors">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                    </svg>
                  </a>
                </div>
              </div>
            </div>
            <h3 class="text-lg font-semibold text-gray-900">{member.name}</h3>
            <p class="text-gray-600">{member.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-gradient-to-br from-primary via-primary-dark to-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
        Ready to Transform Your Business?
      </h2>
      <p class="text-xl text-gray-300 mb-8">
        Let's discuss how our IT solutions can help you achieve your goals.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-teal hover:bg-teal-light text-white px-8 py-4 rounded-lg font-semibold transition-all duration-200 shadow-lg hover:shadow-xl">
          Get in Touch
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="tel:+35722123456" class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white px-8 py-4 rounded-lg font-semibold transition-all duration-200 backdrop-blur-sm border border-white/20">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call Us Now
        </a>
      </div>
    </div>
  </section>
</Layout>
