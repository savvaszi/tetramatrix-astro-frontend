---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
    title: 'UX/UI Design',
    description: 'Your website is your digital storefront. It\'s where potential customers come to learn about your products or services and decide whether to buy from you.',
  },
  {
    icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01',
    title: 'Brand Identity',
    description: 'Your brand identity is what sets you apart from your competitors. It\'s what makes your business unique and memorable.',
  },
  {
    icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
    title: 'Marketing & SEO',
    description: 'Marketing and SEO are essential for any business that wants to succeed online.',
  },
  {
    icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
    title: 'Web Development',
    description: 'Your website is the foundation of your online presence. It\'s where potential customers come to learn about your products or services.',
  },
  {
    icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01',
    title: 'Hosting',
    description: 'Tetramatrix customers can enjoy the fastest possible hosting speeds and the most reliable and secure web servers available.',
  },
];

const caseStudies = [
  { 
    name: 'Sports Hanger', 
    slug: 'sports-hanger',
    url: 'https://sportshanger.com.cy', 
    type: 'Web Design & Development',
    image: 'https://images.unsplash.com/photo-1517836357463-d25dfeac3438?w=800&h=600&fit=crop',
  },
  { 
    name: 'Michalis Charalambides', 
    slug: 'michalis-charalambides',
    url: 'https://michalischaralambides.com/', 
    type: 'Web Design & Development',
    image: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=800&h=600&fit=crop',
  },
  { 
    name: 'Vigour Gym', 
    slug: 'vigour-gym',
    url: 'https://vigourstudio-gym.com/', 
    type: 'Web Design & Development',
    image: 'https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=800&h=600&fit=crop',
  },
  { 
    name: 'Savvas Trichas', 
    slug: 'savvas-trichas',
    url: 'https://savvastrichas.com', 
    type: 'Web Design & Development',
    image: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&h=600&fit=crop',
  },
  { 
    name: 'Aphrodite Homes', 
    slug: 'aphrodite-homes',
    url: 'https://www.aphroditehomes.com/', 
    type: 'Web Design & Development',
    image: 'https://images.unsplash.com/photo-1560518883-ce09059eeffa?w=800&h=600&fit=crop',
  },
  { 
    name: 'Epaidia Private Institute', 
    slug: 'epaidia',
    url: 'https://epaidia.com/', 
    type: 'Web Design & Development, LMS System',
    image: 'https://images.unsplash.com/photo-1523050854058-8df90110c9f1?w=800&h=600&fit=crop',
  },
  { 
    name: 'Ousai Real Estate', 
    slug: 'ousai-real-estate',
    url: 'https://ousai.cy/', 
    type: 'Web Design & Development',
    image: 'https://images.unsplash.com/photo-1560520031-3a4dc4e9de0c?w=800&h=600&fit=crop',
  },
];
---

<Layout title="Home">
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-primary via-primary-dark to-dark overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-20 left-10 w-72 h-72 bg-teal rounded-full blur-3xl"></div>
      <div class="absolute bottom-20 right-10 w-96 h-96 bg-accent rounded-full blur-3xl"></div>
    </div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm rounded-full px-4 py-2 mb-6">
            <span class="w-2 h-2 bg-teal-light rounded-full animate-pulse"></span>
            <span class="text-teal-light text-sm font-medium">Trusted IT Partner in Cyprus</span>
          </div>
          
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
            Digital Products
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-teal-light to-accent"> For Business</span>
          </h1>
          
          <p class="text-lg text-gray-300 mb-8 max-w-xl">
            We create the best digital products for your business. Tetramatrix: Turning ideas into reality.
          </p>
          
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-teal hover:bg-teal-light text-white px-8 py-4 rounded-lg font-semibold transition-all duration-200 shadow-lg hover:shadow-xl">
              Start Your Project
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a href="/services" class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white px-8 py-4 rounded-lg font-semibold transition-all duration-200 backdrop-blur-sm border border-white/20">
              Explore Services
            </a>
          </div>
        </div>
        
        <div class="hidden lg:block relative">
          <div class="relative w-full aspect-square">
            <div class="absolute inset-0 bg-gradient-to-br from-teal/20 to-accent/20 rounded-3xl backdrop-blur-sm border border-white/10"></div>
            <div class="absolute inset-4 bg-gradient-to-br from-primary-light/50 to-primary/50 rounded-2xl flex items-center justify-center">
              <div class="grid grid-cols-2 gap-4 p-8">
                <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/10">
                  <svg class="w-10 h-10 text-teal-light mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                  <p class="text-white/80 text-sm">IT Solutions</p>
                </div>
                <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/10">
                  <svg class="w-10 h-10 text-accent mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />
                  </svg>
                  <p class="text-white/80 text-sm">Cloud Services</p>
                </div>
                <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/10">
                  <svg class="w-10 h-10 text-accent mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                  </svg>
                  <p class="text-white/80 text-sm">Security</p>
                </div>
                <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/10">
                  <svg class="w-10 h-10 text-teal-light mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                  </svg>
                  <p class="text-white/80 text-sm">Development</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white to-transparent"></div>
  </section>

  <!-- Services Section -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-teal font-semibold text-sm uppercase tracking-wider">Our Services</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-3 mb-4">
          Comprehensive IT Solutions
        </h2>
        <p class="text-gray-600 text-lg">
          From strategic consulting to hands-on implementation, we provide end-to-end technology services tailored to your needs.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service) => (
          <div class="group bg-gray-light rounded-2xl p-8 hover:bg-primary hover:shadow-2xl transition-all duration-300">
            <div class="w-14 h-14 bg-primary/10 group-hover:bg-white/20 rounded-xl flex items-center justify-center mb-6 transition-colors">
              <svg class="w-7 h-7 text-primary group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={service.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 group-hover:text-white mb-3 transition-colors">
              {service.title}
            </h3>
            <p class="text-gray-600 group-hover:text-gray-200 transition-colors">
              {service.description}
            </p>
          </div>
        ))}
      </div>

      <div class="text-center mt-12">
        <a href="/services" class="inline-flex items-center gap-2 text-primary hover:text-primary-light font-semibold transition-colors">
          View All Services
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Case Studies Section -->
  <section id="case-studies" class="py-20 lg:py-28 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-teal font-semibold text-sm uppercase tracking-wider">Our Case Studies</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-3 mb-4">
          The Best Solutions for Our Clients
        </h2>
        <p class="text-gray-600 text-lg">
          Tetramatrix has helped businesses of all sizes create effective and engaging websites in a variety of industries, including real estate, e-commerce, education, and entrepreneurship.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {caseStudies.map((study) => (
          <a href={`/case-studies/${study.slug}`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300">
            <div class="aspect-video relative overflow-hidden">
              <img 
                src={study.image} 
                alt={study.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-primary/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            </div>
            <div class="p-6">
              <p class="text-sm text-teal font-medium mb-2">{study.type}</p>
              <h3 class="text-lg font-semibold text-gray-900 group-hover:text-primary transition-colors">{study.name}</h3>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Best Solutions Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
            The Best Solutions for Our Clients
          </h2>
          <p class="text-gray-600 text-lg mb-8">
            Tetramatrix Solutions Ltd has a team of experienced professionals who are experts in their respective fields. They are passionate about helping businesses succeed online, and they are committed to providing their clients with the best possible service.
          </p>
          <p class="text-gray-600 text-lg">
            Tetramatrix Solutions Ltd has a proven track record of success. They have helped businesses of all sizes achieve their online marketing goals. They are a trusted partner for businesses that are looking to grow their online presence and reach their target audience.
          </p>
        </div>
        
        <div class="relative">
          <div class="bg-gradient-to-br from-primary to-primary-dark rounded-2xl p-8 text-white">
            <h3 class="text-2xl font-bold mb-4">Have a Project in Mind?</h3>
            <p class="text-gray-200 mb-6">Do not hesitate to contact us!</p>
            <a href="/contact" class="inline-flex items-center gap-2 bg-teal hover:bg-teal-light text-white px-6 py-3 rounded-lg font-semibold transition-all duration-200">
              Get in Touch
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-gradient-to-br from-primary via-primary-dark to-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
        Turn Ideas into Reality
      </h2>
      <p class="text-xl text-gray-300 mb-8">
        Tetramatrix can turn ideas into reality. We have a team of experienced and talented designers, developers, and marketers who can help you create a website that is both visually appealing and functional.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-teal hover:bg-teal-light text-white px-8 py-4 rounded-lg font-semibold transition-all duration-200 shadow-lg hover:shadow-xl">
          Get in Touch
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="tel:+35770004044" class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white px-8 py-4 rounded-lg font-semibold transition-all duration-200 backdrop-blur-sm border border-white/20">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          70004044
        </a>
      </div>
    </div>
  </section>
</Layout>
