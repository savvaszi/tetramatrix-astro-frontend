---
import Layout from '../layouts/Layout.astro';

const contactInfo = [
  {
    icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
    title: 'Address',
    details: ['Leoforos Archiepiskopou Makariou iii, 175', '2600, Klirou', 'Cyprus'],
  },
  {
    icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
    title: 'Email Address',
    details: ['info@tetramatrix.com.cy'],
    links: true,
  },
  {
    icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z',
    title: 'Phone Numbers',
    details: ['70004044'],
    links: true,
  },
];

const faqs = [
  { question: 'What industries do you serve?', answer: 'We serve a wide range of industries including finance, healthcare, retail, manufacturing, and government sectors.' },
  { question: 'Do you offer 24/7 support?', answer: 'Yes, we offer round-the-clock support for our managed services clients with guaranteed response times.' },
  { question: 'How do you handle data security?', answer: 'We follow industry best practices and comply with GDPR, ISO 27001, and other relevant security standards.' },
  { question: 'What is your typical project timeline?', answer: 'Project timelines vary based on scope, but we typically deliver initial solutions within 4-12 weeks.' },
];
---

<Layout title="Contact" description="Contact Tetramatrix - Let's discuss your great project. Email: info@tetramatrix.com.cy, Phone: 70004044">
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-primary via-primary-dark to-dark py-20 lg:py-28">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-20 right-20 w-72 h-72 bg-teal rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 left-10 w-96 h-96 bg-accent rounded-full blur-3xl"></div>
    </div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block text-teal-light font-semibold text-sm uppercase tracking-wider mb-4">Contact Us</span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6">
        Let's Discuss Your Great Project
      </h1>
      <p class="text-xl text-gray-300 max-w-3xl mx-auto">
        Tetramatrix can turn ideas into reality. We have a team of experienced and talented designers, developers, and marketers who can help you create a website that is both visually appealing and functional.
      </p>
    </div>
  </section>

  <!-- Contact Form & Info Section -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-12">
        <!-- Contact Form -->
        <div class="lg:col-span-2">
          <div class="bg-gray-light rounded-2xl p-8 lg:p-10">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Send Us a Message</h2>
            <form class="space-y-6">
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <label for="firstName" class="block text-sm font-medium text-gray-700 mb-2">First Name</label>
                  <input 
                    type="text" 
                    id="firstName" 
                    name="firstName"
                    class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-teal focus:ring-2 focus:ring-teal/20 outline-none transition-all"
                    placeholder="John"
                    required
                  />
                </div>
                <div>
                  <label for="lastName" class="block text-sm font-medium text-gray-700 mb-2">Last Name</label>
                  <input 
                    type="text" 
                    id="lastName" 
                    name="lastName"
                    class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-teal focus:ring-2 focus:ring-teal/20 outline-none transition-all"
                    placeholder="Doe"
                    required
                  />
                </div>
              </div>
              
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email Address</label>
                  <input 
                    type="email" 
                    id="email" 
                    name="email"
                    class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-teal focus:ring-2 focus:ring-teal/20 outline-none transition-all"
                    placeholder="john@example.com"
                    required
                  />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">Phone Number</label>
                  <input 
                    type="tel" 
                    id="phone" 
                    name="phone"
                    class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-teal focus:ring-2 focus:ring-teal/20 outline-none transition-all"
                    placeholder="+357 99 123 456"
                  />
                </div>
              </div>
              
              <div>
                <label for="service" class="block text-sm font-medium text-gray-700 mb-2">Service Interested In</label>
                <select 
                  id="service" 
                  name="service"
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-teal focus:ring-2 focus:ring-teal/20 outline-none transition-all bg-white"
                >
                  <option value="">Select a service</option>
                  <option value="ux-ui-design">UX/UI Design</option>
                  <option value="brand-identity">Brand Identity</option>
                  <option value="marketing-seo">Marketing & SEO</option>
                  <option value="web-development">Web Development</option>
                  <option value="hosting">Hosting</option>
                  <option value="vpn-setup">VPN Setup</option>
                  <option value="virtualization">Virtualization</option>
                  <option value="other">Other</option>
                </select>
              </div>
              
              <div>
                <label for="message" class="block text-sm font-medium text-gray-700 mb-2">Your Message</label>
                <textarea 
                  id="message" 
                  name="message"
                  rows="5"
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-teal focus:ring-2 focus:ring-teal/20 outline-none transition-all resize-none"
                  placeholder="Tell us about your project..."
                  required
                ></textarea>
              </div>
              
              <button 
                type="submit"
                class="w-full bg-primary hover:bg-primary-light text-white px-8 py-4 rounded-lg font-semibold transition-all duration-200 shadow-lg hover:shadow-xl flex items-center justify-center gap-2"
              >
                Send Message
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </button>
            </form>
          </div>
        </div>
        
        <!-- Contact Info -->
        <div class="space-y-6">
          {contactInfo.map((info) => (
            <div class="bg-gray-light rounded-xl p-6">
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={info.icon} />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900 mb-2">{info.title}</h3>
                  {info.details.map((detail) => (
                    info.links ? (
                      <a href={detail.includes('@') ? `mailto:${detail}` : `tel:${detail.replace(/\s/g, '')}`} class="block text-gray-600 hover:text-teal transition-colors">
                        {detail}
                      </a>
                    ) : (
                      <p class="text-gray-600">{detail}</p>
                    )
                  ))}
                </div>
              </div>
            </div>
          ))}
          
          <!-- Social Links -->
          <div class="bg-primary rounded-xl p-6 text-white">
            <h3 class="font-semibold mb-4">Follow Us</h3>
            <div class="flex gap-4">
              <a href="#" class="w-10 h-10 bg-white/10 rounded-lg flex items-center justify-center hover:bg-white/20 transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </a>
              <a href="#" class="w-10 h-10 bg-white/10 rounded-lg flex items-center justify-center hover:bg-white/20 transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                </svg>
              </a>
              <a href="#" class="w-10 h-10 bg-white/10 rounded-lg flex items-center justify-center hover:bg-white/20 transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section -->
  <section class="h-96 bg-gray-200">
    <iframe 
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d52246.95595670377!2d33.32!3d35.17!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14de1767ca494d55%3A0x324c3c807fc4e0f6!2sNicosia%2C%20Cyprus!5e0!3m2!1sen!2s!4v1234567890"
      width="100%" 
      height="100%" 
      style="border:0;" 
      allowfullscreen="" 
      loading="lazy" 
      referrerpolicy="no-referrer-when-downgrade"
      title="TetraMatrix Office Location"
    ></iframe>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 lg:py-28 bg-gray-light">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-teal font-semibold text-sm uppercase tracking-wider">FAQ</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-3 mb-4">
          Frequently Asked Questions
        </h2>
        <p class="text-gray-600 text-lg">
          Find answers to common questions about our services.
        </p>
      </div>

      <div class="space-y-4">
        {faqs.map((faq, index) => (
          <div class="bg-white rounded-xl overflow-hidden shadow-sm">
            <button 
              class="faq-toggle w-full px-6 py-5 text-left flex items-center justify-between gap-4"
              data-index={index}
            >
              <span class="font-semibold text-gray-900">{faq.question}</span>
              <svg class="faq-icon w-5 h-5 text-gray-500 flex-shrink-0 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-gray-600">{faq.answer}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  document.querySelectorAll('.faq-toggle').forEach((button) => {
    button.addEventListener('click', () => {
      const content = button.nextElementSibling;
      const icon = button.querySelector('.faq-icon');
      
      content?.classList.toggle('hidden');
      icon?.classList.toggle('rotate-180');
    });
  });
</script>
