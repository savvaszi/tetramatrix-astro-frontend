---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    id: 'ux-ui-design',
    icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
    title: 'UX/UI Design',
    description: 'Your website is your digital storefront. It\'s where potential customers come to learn about your products or services and decide whether to buy from you. That\'s why it\'s so important to have a website with a great user experience (UX) and user interface (UI).',
    features: [
      'Increased conversions: A well-designed website will convert more visitors into customers',
      'Improved brand awareness: A visually appealing and informative website will help you build a strong brand identity',
      'Better SEO: A website that is optimized for search engines will rank higher in search results',
      'Increased customer satisfaction: A website with a great UX/UI will make visitors happy',
    ],
  },
  {
    id: 'brand-identity',
    icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01',
    title: 'Brand Identity',
    description: 'Your brand identity is what sets you apart from your competitors. It\'s what makes your business unique and memorable. Your brand identity is reflected in everything from your logo and tagline to your website and marketing materials.',
    features: [
      'Increased brand awareness: A strong brand identity will help you build brand awareness',
      'Improved customer loyalty: Customers are more likely to be loyal to brands that have a strong identity',
      'Differentiation from competitors: A unique brand identity will help you set yourself apart',
      'Increased sales: A strong brand identity can lead to increased sales and revenue',
    ],
  },
  {
    id: 'marketing-seo',
    icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
    title: 'Marketing & SEO',
    description: 'Marketing and SEO are essential for any business that wants to succeed online. Marketing helps you reach your target audience and generate leads. SEO helps your website rank higher in search results.',
    features: [
      'Content marketing: Create and distribute high-quality content that will attract visitors',
      'Social media marketing: Manage your social media accounts and create engaging content',
      'Search engine optimization (SEO): Optimize your website to rank higher in search results',
      'Pay-per-click (PPC) advertising: Create and manage PPC campaigns to drive traffic',
    ],
  },
  {
    id: 'web-development',
    icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
    title: 'Web Development',
    description: 'Your website is the foundation of your online presence. It\'s where potential customers come to learn about your products or services and decide whether to buy from you. That\'s why it\'s so important to have a website that is well-designed, developed, and secure.',
    features: [
      'Website design and development: Create a custom website that meets your specific needs',
      'Content management systems (CMS): Choose and implement the right CMS for your website',
      'E-commerce solutions: Build online stores with secure payment processing',
      'Responsive design: Ensure your website works perfectly on all devices',
    ],
  },
  {
    id: 'hosting',
    icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01',
    title: 'Hosting',
    description: 'Tetramatrix is one of the fastest and most reliable web hosting providers. We use NVMe drives for hosting and Nginx, LiteSpeed, and OpenLiteSpeed stacks for the fastest possible hosting speeds.',
    features: [
      'NVMe SSD storage for lightning-fast performance',
      'Nginx, LiteSpeed, and OpenLiteSpeed web servers',
      '100% satisfaction guarantee',
      'Wide range of hosting plans to choose from',
    ],
  },
  {
    id: 'vpn-setup',
    icon: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z',
    title: 'VPN Setup',
    description: 'Empower your business with secure and unrestricted internet access through Tetramatrix VPN services for routers. Grant seamless, encrypted connections to all your company devices.',
    features: [
      'Secure and encrypted connections for all devices',
      'Bypass geographical restrictions',
      'Protect business communications and data transfers',
      'Single subscription for all connected devices',
    ],
  },
  {
    id: 'virtualization',
    icon: 'M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10',
    title: 'Virtualization',
    description: 'Secure your business with Virtual Machines: Cost-effective powerhouse for enhanced security. Virtual machines (VMs) are software-based computers running on top of a physical machine.',
    features: [
      'Reduced costs: Cut hardware expenses with VM consolidation',
      'Increased security through isolation',
      'Effortless scaling: Quickly add or remove VMs as needed',
      'Disaster recovery made simple with VM backups',
    ],
  },
];

const process = [
  { step: '01', title: 'Discovery', description: 'We analyze your current infrastructure and understand your business goals.' },
  { step: '02', title: 'Strategy', description: 'Our experts develop a tailored technology roadmap for your organization.' },
  { step: '03', title: 'Implementation', description: 'We execute the plan with precision, ensuring minimal disruption.' },
  { step: '04', title: 'Support', description: 'Ongoing maintenance and support to keep your systems running optimally.' },
];
---

<Layout title="Services" description="We create the best digital products for your business - UX/UI Design, Brand Identity, Marketing & SEO, Web Development, Hosting, VPN Setup, and Virtualization.">
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-primary via-primary-dark to-dark py-20 lg:py-28">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-20 right-20 w-72 h-72 bg-teal rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 left-10 w-96 h-96 bg-accent rounded-full blur-3xl"></div>
    </div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block text-teal-light font-semibold text-sm uppercase tracking-wider mb-4">Our Services</span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6">
        Best Solutions For Your Business
      </h1>
      <p class="text-xl text-gray-300 max-w-3xl mx-auto">
        We create the best digital products for your business. From UX/UI design to web development, hosting, and virtualization.
      </p>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-8">
        {services.map((service) => (
          <div id={service.id} class="bg-gray-light rounded-2xl p-8 lg:p-10 hover:shadow-xl transition-shadow duration-300">
            <div class="flex items-start gap-6">
              <div class="w-16 h-16 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={service.icon} />
                </svg>
              </div>
              <div class="flex-1">
                <h2 class="text-2xl font-bold text-gray-900 mb-3">{service.title}</h2>
                <p class="text-gray-600 mb-6">{service.description}</p>
                <ul class="space-y-3">
                  {service.features.map((feature) => (
                    <li class="flex items-center gap-3 text-gray-700">
                      <svg class="w-5 h-5 text-teal flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      {feature}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="py-20 lg:py-28 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-teal font-semibold text-sm uppercase tracking-wider">Our Process</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-3 mb-4">
          How We Work
        </h2>
        <p class="text-gray-600 text-lg">
          A proven methodology that ensures successful project delivery every time.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {process.map((item, index) => (
          <div class="relative">
            <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow h-full">
              <div class="text-5xl font-bold text-primary/10 mb-4">{item.step}</div>
              <h3 class="text-xl font-semibold text-gray-900 mb-3">{item.title}</h3>
              <p class="text-gray-600">{item.description}</p>
            </div>
            {index < process.length - 1 && (
              <div class="hidden lg:block absolute top-1/2 -right-4 transform -translate-y-1/2 z-10">
                <svg class="w-8 h-8 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Technologies Section -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-teal font-semibold text-sm uppercase tracking-wider">Technologies</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-3 mb-4">
          Tools & Platforms We Use
        </h2>
        <p class="text-gray-600 text-lg">
          We leverage industry-leading technologies to deliver robust solutions.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-8">
        {['AWS', 'Azure', 'Google Cloud', 'Docker', 'Kubernetes', 'React', 'Node.js', 'Python', 'PostgreSQL', 'MongoDB', 'Terraform', 'Jenkins'].map((tech) => (
          <div class="bg-gray-light rounded-xl p-6 flex items-center justify-center hover:bg-primary hover:text-white transition-colors group">
            <span class="font-semibold text-gray-700 group-hover:text-white">{tech}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-gradient-to-br from-primary via-primary-dark to-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
        Ready to Get Started?
      </h2>
      <p class="text-xl text-gray-300 mb-8">
        Let's discuss how our services can help transform your business.
      </p>
      <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-teal hover:bg-teal-light text-white px-8 py-4 rounded-lg font-semibold transition-all duration-200 shadow-lg hover:shadow-xl">
        Contact Us Today
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>
</Layout>
