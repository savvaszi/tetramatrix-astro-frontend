---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { getLangFromUrl, t, getLocalizedPath } from '../lib/i18n';

const currentLang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: getLocalizedPath('/', currentLang), label: t(currentLang, 'nav.home') },
  { href: getLocalizedPath('/services', currentLang), label: t(currentLang, 'nav.services') },
  { href: getLocalizedPath('/tetrapos', currentLang), label: t(currentLang, 'nav.tetrapos') },
  { href: getLocalizedPath('/about', currentLang), label: t(currentLang, 'nav.about') },
  { href: getLocalizedPath('/contact', currentLang), label: t(currentLang, 'nav.contact') },
];

const homeHref = getLocalizedPath('/', currentLang);
const contactHref = getLocalizedPath('/contact', currentLang);
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100 shadow-sm">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <a href={homeHref} class="flex items-center gap-3">
        <img 
          src="/TetramatrixMainLogo1.webp" 
          alt="TetraMatrix Logo" 
          class="h-12 w-auto"
        />
      </a>

      <div class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`text-sm font-medium transition-colors duration-200 ${
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-primary'
                : 'text-gray-700 hover:text-primary'
            }`}
          >
            {link.label}
          </a>
        ))}
        <a
          href={contactHref}
          class="bg-primary hover:bg-primary-light text-white px-6 py-2.5 rounded-lg text-sm font-semibold transition-all duration-200 shadow-md hover:shadow-lg"
        >
          {t(currentLang, 'nav.getStarted')}
        </a>
        <LanguageSwitcher />
      </div>

      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-gray-700 hover:text-primary"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <div class="flex flex-col gap-4">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`text-sm font-medium py-2 ${
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-primary'
                : 'text-gray-700'
            }`}
          >
            {link.label}
          </a>
        ))}
        <a
          href={contactHref}
          class="bg-primary text-white px-6 py-2.5 rounded-lg text-sm font-semibold text-center"
        >
          {t(currentLang, 'nav.getStarted')}
        </a>
        <LanguageSwitcher />
      </div>
    </div>
  </nav>
</header>

<div class="h-20"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
