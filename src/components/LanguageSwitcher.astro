---
import { languages, getLangFromUrl, getAlternateUrls } from '../lib/i18n';

const currentLang = getLangFromUrl(Astro.url);
const alternateUrls = getAlternateUrls(Astro.url);
---

<div class="relative" id="lang-switcher">
  <button 
    id="lang-btn"
    class="flex items-center gap-2 px-3 py-2 text-sm font-medium text-gray-700 hover:text-primary transition-colors rounded-lg hover:bg-gray-100"
    aria-label="Select language"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
    </svg>
    <span class="uppercase">{currentLang}</span>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </button>
  
  <div 
    id="lang-dropdown"
    class="hidden absolute right-0 mt-2 w-40 bg-white rounded-lg shadow-lg border border-gray-100 py-2 z-50"
  >
    {Object.entries(languages).map(([code, name]) => (
      <a 
        href={alternateUrls[code as keyof typeof languages]}
        class={`block px-4 py-2 text-sm hover:bg-gray-50 transition-colors ${
          code === currentLang ? 'text-primary font-medium bg-primary/5' : 'text-gray-700'
        }`}
      >
        <span class="flex items-center gap-2">
          {code === 'en' && <span>🇬🇧</span>}
          {code === 'el' && <span>🇬🇷</span>}
          {name}
        </span>
      </a>
    ))}
  </div>
</div>

<script>
  const btn = document.getElementById('lang-btn');
  const dropdown = document.getElementById('lang-dropdown');
  
  btn?.addEventListener('click', (e) => {
    e.stopPropagation();
    dropdown?.classList.toggle('hidden');
  });
  
  document.addEventListener('click', () => {
    dropdown?.classList.add('hidden');
  });
</script>
